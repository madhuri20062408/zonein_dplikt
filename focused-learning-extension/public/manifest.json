{
  "manifest_version": 3,
  "name": "ZoneIn",
  "version": "1.1",
  "description": "Transform YouTube into a distraction-free learning platform.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "windows",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5173/*",
    "https://your-deployed-backend.com/*"
  ],
  "externally_connectable": {
    "matches": ["http://localhost:5173/*"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "dist/index.html",
    "default_title": "ZoneIn",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "http://localhost:5173/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}